      "data_type": "enum",
      "required": false,
      "description": "Clear, lien reported, unknown"
    },
    {
      "field_name": "acquisition_path",
      "data_type": "enum",
      "required": true,
      "description": "Consignment or direct purchase candidate"
    },
    {
      "field_name": "running_status",
      "data_type": "enum",
      "required": true,
      "description": "Running, partial, non-running"
    },
    {
      "field_name": "can_cold_start",
      "data_type": "boolean",
      "required": true,
      "description": "Was cold start observed"
    },
    {
      "field_name": "emissions_tier",
      "data_type": "enum",
      "required": false,
      "description": "Tier/Stage label if visible"
    },
    {
      "field_name": "cab_type",
      "data_type": "enum",
      "required": true,
      "description": "Open station, canopy, enclosed cab"
    },
    {
      "field_name": "rops_present",
      "data_type": "boolean",
      "required": true,
      "description": "ROPS/FOPS present if applicable"
    },
    {
      "field_name": "transport_notes",
      "data_type": "text",
      "required": false,
      "description": "Only key issues affecting pickup to yard"
    },
    {
      "field_name": "service_records_available",
      "data_type": "boolean",
      "required": true,
      "description": "Maintenance records available"
    },
    {
      "field_name": "major_rebuild_history",
      "data_type": "text",
      "required": false,
      "description": "Engine, transmission, hydraulic, UC rebuilds"
    },
    {
      "field_name": "overall_cosmetic_condition",
      "data_type": "enum",
      "required": true,
      "description": "Excellent/Good/Fair/Poor/Inoperable/Not Verified"
    },
    {
      "field_name": "marketability_rating",
      "data_type": "enum",
      "required": true,
      "description": "Fast sell, average, slow sell, salvage risk"
    },
    {
      "field_name": "photo_set_complete",
      "data_type": "boolean",
      "required": true,
      "description": "Required photos captured"
    },
    {
      "field_name": "listing_notes",
      "data_type": "text",
      "required": false,
      "description": "Market-facing descriptive notes"
    },
    {
      "field_name": "red_flags_summary",
      "data_type": "text",
      "required": false,
      "description": "Major issues affecting value or listing"
    }
  ],
  "condition_scale": [
    {
      "score": 5,
      "label": "Excellent",
      "definition": "Low-hour or exceptionally maintained unit. Clean, fully functional, strong cosmetics, no material leaks, no immediate repairs expected."
    },
    {
      "score": 4,
      "label": "Good",
      "definition": "Normal used condition for age/hours. Fully operational with minor wear, minor cosmetic flaws, and no major immediate repair needed."
    },
    {
      "score": 3,
      "label": "Fair",
      "definition": "Operational but shows meaningful wear. Multiple defects or deferred maintenance present. Marketability reduced and buyer likely expects repairs."
    },
    {
      "score": 2,
      "label": "Poor",
      "definition": "Runs or partially functions but has major defects, structural concerns, heavy leakage, significant wear, or failed systems. Strong value discount."
    },
    {
      "score": 1,
      "label": "Inoperable",
      "definition": "Non-running or unable to demonstrate critical functions. Salvage, parts, or major project unit unless repaired."
    },
    {
      "score": 0,
      "label": "Not Verified",
      "definition": "Tech could not inspect or confirm. Use sparingly and explain why."
    }
  ],
