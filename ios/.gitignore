# ABOUTME: Xcode build/user state — keep source files but never commit derived artifacts.
# ABOUTME: .xcodeproj is generated by `xcodegen generate` from project.yml; not tracked.

# Xcode user state — per-developer, never shared.
xcuserdata/
*.xcuserstate
*.xcuserdatad/

# Generated Xcode project — XcodeGen produces this from project.yml.
# Re-run `xcodegen generate` after pulling. Tracking the .xcodeproj
# would mean every contributor's Xcode version churns the file.
TempleHEAppraiser.xcodeproj/

# Build outputs.
build/
DerivedData/
*.ipa
*.xcarchive
*.dSYM/

# Swift Package Manager caches.
.build/
Package.resolved
.swiftpm/

# Fastlane.
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output

# CocoaPods (we're not using it today; guard anyway).
Pods/

# macOS detritus.
.DS_Store

# IDE state.
.vscode/
.idea/
