# ABOUTME: Frontend env vars for local dev. Copy to web/.env.local and edit as needed.
# ABOUTME: VITE_* variables are embedded in the built bundle — never put secrets here.

# API base URL. Leave unset to use Vite's dev proxy (forwards /api to :8000).
# VITE_API_BASE_URL=http://localhost:8000/api/v1

# Public R2 bucket URL, used to render photo thumbnails on the detail page.
# Leave unset during development — thumbnails render as a storage_key placeholder.
# VITE_R2_PUBLIC_URL=https://temple-he-photos.r2.cloudflarestorage.com
