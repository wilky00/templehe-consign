# ABOUTME: Environment variable template. Copy to .env and fill in values.
# ABOUTME: Never commit .env — only .env.example is tracked in git.

# =============================================================================
# Database
# =============================================================================
# NEON (staging/prod/dev via Neon branches):
# DATABASE_URL      → pooler endpoint (PgBouncer) — app runtime
# DATABASE_DIRECT_URL → direct endpoint, no pooler — Alembic migrations only
# Format: postgresql+asyncpg://user:password@<endpoint>.neon.tech/neondb?ssl=require
# Both endpoints are on the Neon dashboard → project → branch → Connection Details.
DATABASE_URL=postgresql+asyncpg://neondb_owner:<password>@<pooler-endpoint>.neon.tech/neondb?ssl=require
DATABASE_DIRECT_URL=postgresql+asyncpg://neondb_owner:<password>@<direct-endpoint>.neon.tech/neondb?ssl=require

# LOCAL FALLBACK (Docker Compose Postgres — swap DATABASE_URL to this when running offline)
# DATABASE_URL=postgresql+asyncpg://templehe:devpassword@localhost:5432/templehe
POSTGRES_PASSWORD=devpassword

# Test database (used by integration tests — always local Docker)
TEST_DATABASE_URL=postgresql+asyncpg://templehe:devpassword@localhost:5432/templehe_test

# =============================================================================
# JWT
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# TOTP / 2FA
# =============================================================================
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=

# =============================================================================
# Email (SendGrid)
# =============================================================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@saltrun.net
SENDGRID_FROM_NAME=Temple Heavy Equipment

# Local dev: use Mailpit SMTP instead of SendGrid
SMTP_HOST=localhost
SMTP_PORT=1025

# =============================================================================
# SMS (Twilio — A2P 10DLC registration required before production use)
# =============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# =============================================================================
# Object Storage (Cloudflare R2)
# =============================================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PHOTOS=temple-he-photos
R2_BUCKET_REPORTS=temple-he-reports
R2_BUCKET_BACKUPS=temple-he-backups
R2_PUBLIC_URL=

# =============================================================================
# Observability
# =============================================================================
SENTRY_DSN=
BETTERSTACK_SOURCE_TOKEN=

# =============================================================================
# Google OAuth (Phase 1 stub — not implemented until explicitly scheduled)
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Staff domain restriction (e.g. templehe.com)
GOOGLE_WORKSPACE_DOMAIN=

# =============================================================================
# Application
# =============================================================================
ENVIRONMENT=development
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Seed
# =============================================================================
# Admin user created by scripts/seed.py — never hardcode these
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
